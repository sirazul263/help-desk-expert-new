generator client {
    provider = "prisma-client-js"
    output   = "../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
}

// ── NextAuth required tables ──────────────────────────
model Account {
    id                String  @id @default(cuid())
    userId            String  @map("user_id")
    type              String
    provider          String
    providerAccountId String  @map("provider_account_id")
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@map("accounts")
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique @map("session_token")
    userId       String   @map("user_id")
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("sessions")
}

model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
    @@map("verification_tokens")
}

// ── App tables ────────────────────────────────────────
model User {
    id            String    @id @default(cuid())
    firstName     String    @map("first_name")
    lastName      String    @map("last_name")
    email         String    @unique
    emailVerified DateTime? @map("email_verified")
    company       String?
    password      String
    role          String    @default("USER") // "USER" | "ADMIN"
    isActive      Boolean   @default(true) @map("is_active")
    image         String?
    createdAt     DateTime  @default(now()) @map("created_at")
    updatedAt     DateTime  @updatedAt @map("updated_at")
    lastLogin     DateTime? @map("last_login")

    accounts          Account[]
    sessions          Session[]
    resetTokens       ResetToken[]
    invoices          Invoice[]
    chatConversations ChatConversation[]
    adminMessages      ChatMessage[]
    reviews            Review[]
    sentEmails         SentEmail[]
    promoCampaigns     PromotionalCampaign[]

    @@map("users")
}

model ResetToken {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    token     String   @unique
    expiresAt DateTime @map("expires_at")
    used      Boolean  @default(false)
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([token])
    @@map("reset_tokens")
}

model LoginAttempt {
    id        String   @id @default(cuid())
    email     String
    ipAddress String?  @map("ip_address")
    success   Boolean  @default(false)
    createdAt DateTime @default(now()) @map("created_at")

    @@index([email])
    @@map("login_attempts")
}

// ── Invoices ──────────────────────────────────────────
model Invoice {
    id        String   @id @default(cuid())
    num       String   @unique
    clientId  String   @map("client_id")
    issued    DateTime
    due       DateTime
    status    String   @default("Unpaid") // Draft | Unpaid | Paid | Overdue
    tax       Float    @default(10)
    bank      String   @default("")
    notes     String   @default("")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    client User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
    items  InvoiceItem[]

    @@index([clientId])
    @@map("invoices")
}

model InvoiceItem {
    id        String @id @default(cuid())
    invoiceId String @map("invoice_id")
    desc      String
    qty       Int    @default(1)
    price     Float  @default(0)

    invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

    @@index([invoiceId])
    @@map("invoice_items")
}

// ── Screen Share ─────────────────────────────────────
model ScreenSession {
    id        String   @id @default(cuid())
    agentId   String   @map("agent_id")
    agentName String   @map("agent_name")
    status    String   @default("waiting") // waiting | live | ended
    offer     String?  @db.Text
    answer    String?  @db.Text
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    iceCandidates ScreenIceCandidate[]
    chatMessages  ScreenChatMsg[]

    @@index([agentId])
    @@map("screen_sessions")
}

model ScreenIceCandidate {
    id        String   @id @default(cuid())
    sessionId String   @map("session_id")
    role      String // agent | client
    candidate String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    session ScreenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@index([sessionId, role])
    @@map("screen_ice_candidates")
}

model ScreenChatMsg {
    id        String   @id @default(cuid())
    sessionId String   @map("session_id")
    role      String // agent | client
    name      String
    text      String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    session ScreenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@index([sessionId, createdAt])
    @@map("screen_chat_msgs")
}

// ── Consultations ─────────────────────────────────────
model Consultation {
    id        String   @id @default(cuid())
    firstName String   @map("first_name")
    lastName  String   @map("last_name")
    email     String
    company   String
    role      String
    website   String   @default("")
    agents    String
    channels  String   @default("")
    volume    String
    tool      String   @default("")
    notes     String   @default("") @db.Text
    date      String
    time      String
    timezone  String
    source    String   @default("")
    status    String   @default("pending") // pending | in_progress | completed
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@index([status])
    @@index([createdAt])
    @@map("consultations")
}

// ── Reviews ───────────────────────────────────────────
model Review {
    id          String   @id @default(cuid())
    userId      String   @map("user_id")
    rating      Int      @default(5)
    quote       String   @db.Text
    role        String   @default("")
    isPublished Boolean  @default(true) @map("is_published")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([isPublished])
    @@map("reviews")
}

// ── Chat ──────────────────────────────────────────────
model ChatConversation {
    id        String   @id @default(cuid())
    userId    String?  @map("user_id")
    email     String
    name      String   @default("")
    status    String   @default("open") // "open" | "closed"
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
    messages ChatMessage[]

    @@index([email])
    @@index([status])
    @@map("chat_conversations")
}

model ChatMessage {
    id             String   @id @default(cuid())
    conversationId String   @map("conversation_id")
    sender         String // "user" | "admin"
    body           String   @default("")
    fileUrl        String?  @map("file_url")
    fileName       String?  @map("file_name")
    fileType       String?  @map("file_type")
    adminId        String?  @map("admin_id")
    adminName      String?  @map("admin_name")
    isRead         Boolean  @default(false) @map("is_read")
    createdAt      DateTime @default(now()) @map("created_at")

    conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    admin        User?            @relation(fields: [adminId], references: [id], onDelete: SetNull)

    @@index([conversationId])
    @@index([adminId])
    @@map("chat_messages")
}

// ── Sent Emails ───────────────────────────────────────
model SentEmail {
    id      String   @id @default(cuid())
    to      String
    subject String
    body    String   @db.Text
    sentBy  String   @map("sent_by")
    sentAt  DateTime @default(now()) @map("sent_at")
    status  String   @default("sent") // sent | failed
    error   String?  @db.Text

    admin User @relation(fields: [sentBy], references: [id], onDelete: Cascade)

    @@index([sentBy])
    @@index([sentAt])
    @@map("sent_emails")
}

// ── Promotional Campaigns ─────────────────────────────
model PromotionalCampaign {
    id        String   @id @default(cuid())
    subject   String
    sentBy    String   @map("sent_by")
    sentAt    DateTime @default(now()) @map("sent_at")
    total     Int      @default(0)
    succeeded Int      @default(0)
    failed    Int      @default(0)

    admin      User                     @relation(fields: [sentBy], references: [id], onDelete: Cascade)
    recipients PromoCampaignRecipient[]

    @@index([sentBy])
    @@index([sentAt])
    @@map("promotional_campaigns")
}

model PromoCampaignRecipient {
    id         String  @id @default(cuid())
    campaignId String  @map("campaign_id")
    email      String
    status     String  @default("sent") // sent | failed
    error      String? @db.Text

    campaign PromotionalCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

    @@index([campaignId])
    @@map("promo_campaign_recipients")
}
